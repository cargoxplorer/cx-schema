{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Field Component",
  "type": "object",
  "properties": {
    "component": {
      "type": "string",
      "const": "field"
    },
    "name": {
      "type": "string",
      "description": "Field name (form field path)",
      "x-example": "countryCode"
    },
    "props": {
      "type": "object",
      "properties": {
        "label": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "$ref": "../schemas.json#/definitions/localized"
            },
            {
              "type": "null"
            }
          ],
          "x-example": {
            "en-US": "Country Code"
          }
        },
        "placeholder": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "$ref": "../schemas.json#/definitions/localized"
            }
          ],
          "description": "Field placeholder text. Supports plain strings or localized values.",
          "x-example": {
            "en-US": "Enter Country Code"
          }
        },
        "type": {
          "type": "string",
          "enum": [
            "text",
            "number",
            "number-select",
            "email",
            "password",
            "tel",
            "url",
            "date",
            "datetime",
            "rangedatetime",
            "enhanced-rangedatetime",
            "time",
            "select",
            "select-async",
            "autocomplete",
            "autocomplete-async",
            "autocomplete-googleplaces",
            "checkbox",
            "radio",
            "toggle",
            "textarea",
            "attachment",
            "secret",
            "file",
            "hidden",
            "phone",
            "quill",
            "object",
            "yaml",
            "display"
          ],
          "description": "Field input type",
          "x-example": "select-async"
        },
        "required": {
          "type": "boolean",
          "description": "Whether field is required",
          "x-example": true
        },
        "disabled": {
          "type": [
            "boolean",
            "string"
          ],
          "description": "Whether field is disabled (string = template expression; renderer uses parseTemplate)",
          "x-example": false
        },
        "min": { "type": "number", "description": "Minimum value for numeric field types" },
        "max": { "type": "number", "description": "Maximum value for numeric field types" },
        "step": { "type": "number", "description": "Step increment for number-select arrow controls" },
        "secretPath": {
          "type": "string",
          "description": "Template expression for the secret name used by secret fields, e.g. integrations/{{ id }}/apiKey"
        },
        "options": {
          "type": [
            "object",
            "null"
          ],
          "description": "Field options for select types",
          "properties": {
            "variant": {
              "type": "string"
            },
            "size": {
              "type": "string"
            },
            "allowInlineCreate": {
              "type": "boolean"
            },
            "allowCreate": {
              "type": "boolean",
              "description": "Alias for allowInlineCreate"
            },
            "allowMultiple": {
              "type": "boolean"
            },
            "allowClear": {
              "type": "boolean"
            },
            "allowSearch": {
              "type": "boolean"
            },
            "placeholder": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "$ref": "../schemas.json#/definitions/localized"
                }
              ],
              "description": "Select placeholder text. Supports plain strings or localized values."
            },
            "minWidth": {
              "type": "string"
            },
            "valueFieldName": {
              "type": "string",
              "description": "Field name to use as the value for select options",
              "x-example": "countryCode"
            },
            "itemLabelTemplate": {
              "type": "string",
              "description": "Template expression for option labels",
              "x-example": "{{countryName}}"
            },
            "itemValueTemplate": {
              "type": "string",
              "description": "Template expression for option values",
              "x-example": "{{countryCode}}"
            },
            "navigateActionPermission": {
              "type": "string",
              "description": "Permission required for navigation actions",
              "x-example": "System/Countries/Update"
            },
            "searchQuery": {
              "type": "object",
              "description": "Query configuration for async search",
              "properties": {
                "name": {
                  "type": "string",
                  "x-example": "getCountries"
                },
                "path": {
                  "type": "string",
                  "description": "Path to data in query result",
                  "x-example": "countries.items"
                },
                "params": {
                  "type": "object",
                  "description": "Query parameters",
                  "additionalProperties": true,
                  "x-example": {
                    "search": "{{ string search }}",
                    "take": "{{ number pageSize }}",
                    "skip": "{{ number skip }}",
                    "filter": "{{ string filter }}"
                  }
                }
              }
            },
            "valueQuery": {
              "type": "object",
              "description": "Query configuration for fetching selected value",
              "properties": {
                "name": {
                  "type": "string"
                },
                "path": {
                  "type": "string",
                  "description": "Path to data in query result"
                },
                "params": {
                  "type": "object",
                  "description": "Query parameters",
                  "additionalProperties": true
                }
              }
            },
            "defaultValues": {
              "type": "object",
              "description": "Default values for the field",
              "additionalProperties": true
            },
            "color": { "type": "string" },
            "orientation": { "type": "string" }
          },
          "additionalProperties": true
        },
        "dropDownToolbar": {
          "type": [
            "array",
            "null"
          ],
          "description": "Toolbar components for dropdown",
          "items": {
            "$ref": "../schemas.json#/definitions/component"
          }
        },
        "queries": {
          "type": "array",
          "description": "Field-specific queries for select-async fields",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "query": {
                "type": "object",
                "properties": {
                  "command": {
                    "type": "string"
                  },
                  "variables": {
                    "type": "object",
                    "additionalProperties": true
                  }
                }
              }
            }
          }
        },
        "onEditClick": {
          "$ref": "../schemas.json#/definitions/actionsList",
          "description": "Actions to execute when the edit icon is clicked. Rendered for text, select-async, and autocomplete-async fields when a single value is set."
        },
        "onOptionTagClick": {
          "$ref": "../schemas.json#/definitions/actionsList",
          "description": "Actions to execute when clicking on an option tag/chip in the dropdown"
        },
        "items": {
          "type": [
            "array",
            "null"
          ],
          "description": "Static options for select, radio, and toggle fields",
          "items": {
            "type": [
              "object",
              "string"
            ],
            "properties": {
              "label": {
                "type": "string"
              },
              "value": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "number"
                  },
                  {
                    "type": "boolean"
                  }
                ]
              }
            },
            "required": [
              "label",
              "value"
            ]
          }
        },
        "transformValue": {
          "type": "object",
          "description": "Value transformation configuration",
          "properties": {
            "onLoad": {
              "type": "string",
              "description": "Template expression to transform value on load"
            },
            "onChange": {
              "type": "string",
              "description": "Template expression to transform value on change"
            },
            "onBlur": {
              "type": "string",
              "description": "Template expression to transform value on blur"
            }
          }
        },
        "onChange": {
          "$ref": "../schemas.json#/definitions/triggerActions"
        },
        "onBlur": {
          "$ref": "../schemas.json#/definitions/actionsList"
        },
        "onFocus": {
          "$ref": "../schemas.json#/definitions/actionsList"
        },
        "onSelectValue": {
          "$ref": "../schemas.json#/definitions/actionsList",
          "description": "Actions to execute when a value is selected in select-async fields"
        },
        "allowMultiple": {
          "type": "boolean",
          "description": "Toggle field multi-select mode (array value when true)."
        },
        "exclusive": {
          "type": "boolean",
          "description": "Legacy toggle single-select flag; prefer allowMultiple."
        },
        "enforceValue": {
          "type": "boolean",
          "description": "Toggle single-select mode: prevent deselecting the current value."
        },
        "defaultValue": {
          "description": "Initial field value."
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "props": {
            "properties": {
              "type": {
                "const": "select"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "props": {
            "required": [
              "items"
            ]
          }
        }
      }
    }
  ],
  "required": [
    "component",
    "name"
  ],
  "x-examples": [
    {
      "component": "field",
      "name": "calendarType",
      "props": {
        "label": {
          "en-US": "Calendar Type"
        },
        "type": "select",
        "options": {
          "placeholder": "Select Calendar Type"
        },
        "items": [
          {
            "label": "Standard",
            "value": "Standard"
          },
          {
            "label": "Resource",
            "value": "Resource"
          },
          {
            "label": "Personal",
            "value": "Personal"
          }
        ]
      }
    },
    {
      "component": "field",
      "name": "countryId",
      "props": {
        "label": {
          "en-US": "Country"
        },
        "type": "select-async",
        "options": {
          "allowSearch": true,
          "allowClear": true,
          "searchQuery": {
            "name": "getCountries",
            "path": "countries.items",
            "params": {
              "search": "{{ string search }}",
              "take": "{{ number pageSize }}",
              "skip": "{{ number skip }}",
              "filter": "{{ string filter }}"
            }
          }
        }
      }
    },
    {
      "component": "field",
      "name": "tags",
      "props": {
        "label": {
          "en-US": "Tags"
        },
        "type": "select-async",
        "onOptionTagClick": [
          {
            "dialog": {
              "name": "editTagDialog",
              "props": {
                "title": {
                  "en-US": "Edit Tag"
                }
              },
              "component": {
                "component": "layout",
                "children": [
                  {
                    "component": "Tags/EditTag"
                  }
                ]
              }
            }
          }
        ]
      }
    },
    {
      "component": "field",
      "name": "description",
      "props": {
        "label": {
          "en-US": "Description"
        },
        "type": "text",
        "placeholder": {
          "en-US": "Enter description"
        }
      }
    }
  ]
}
