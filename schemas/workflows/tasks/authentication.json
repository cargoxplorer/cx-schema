{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Authentication Tasks",
  "description": "Authentication and OAuth operations",
  "type": "object",
  "properties": {
    "task": {
      "type": "string",
      "enum": [
        "Authentication/OAuth2"
      ],
      "description": "Task type identifier"
    },
    "name": {
      "type": "string",
      "description": "Step name identifier"
    },
    "description": {
      "type": "string",
      "description": "Step description"
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "expression": { "type": "string" }
        },
        "required": ["expression"]
      }
    },
    "continueOnError": {
      "type": "boolean"
    },
    "inputs": {
      "type": "object",
      "description": "OAuth2 authentication inputs",
      "properties": {
        "credentials": {
          "type": "object",
          "description": "OAuth2 credentials object (e.g., grant_type, client_id, client_secret)",
          "additionalProperties": true
        },
        "tokenUrl": {
          "type": "string",
          "description": "Token endpoint URL"
        },
        "headers": {
          "type": "array",
          "description": "Optional HTTP headers for the token request",
          "items": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "retryOptions": {
          "type": "object",
          "description": "Optional retry configuration for the HTTP request",
          "additionalProperties": true
        },
        "cache": {
          "type": "boolean",
          "description": "Enable token caching (default: true). Set to false to always fetch a new token.",
          "default": true
        }
      },
      "required": ["credentials", "tokenUrl"],
      "additionalProperties": true
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "mapping": { "type": "string" }
        },
        "required": ["name", "mapping"]
      }
    }
  },
  "required": ["task"],
  "additionalProperties": true
}
